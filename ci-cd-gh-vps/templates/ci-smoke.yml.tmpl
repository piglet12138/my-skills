name: CI · Build & __PROJECT__ Smoke

# Push → build artifact on GH runner → scp to VPS → run smoke as
# unprivileged user → fail-fast on auth issues via pre-flight curl.
#
# Placeholders to replace before use:
#   __PROJECT__       — project name (display only, in step names)
#   __INSTALL_DIR__   — remote dir (e.g. /opt/claw)
#   __RUNTIME_USER__  — unprivileged user on VPS (e.g. claw)
#   __ARTIFACT__      — bundle path (e.g. dist/cli.mjs)
#   __BUILD_CMD__     — build command (e.g. bun run build)
#
# Secrets used (rename the prefix to match your project):
#   __PROJECT__UPPER_HOST, __PROJECT__UPPER_USER, __PROJECT__UPPER_SSH_KEY
#   SMOKE_API_KEY (whatever the smoke needs)

on:
  push:
    branches:
      - main
      - 'feat/**'
  pull_request:
    branches: [main]
  workflow_dispatch:

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  build-and-smoke:
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - uses: actions/checkout@v4

      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      - name: Install deps
        run: bun install --frozen-lockfile

      - name: Build __PROJECT__ bundle
        run: __BUILD_CMD__

      - name: Verify bundle exists
        run: |
          test -s __ARTIFACT__
          ls -lh __ARTIFACT__

      - name: Upload bundle + smoke script to VPS
        uses: appleboy/scp-action@v0.1.7
        with:
          host:     ${{ secrets.VOLC_HOST }}
          username: ${{ secrets.VOLC_USER }}
          key:      ${{ secrets.VOLC_SSH_KEY }}
          source:   "__ARTIFACT__,scripts/ci-smoke.sh"
          target:   "__INSTALL_DIR__/"
          strip_components: 0

      - name: Remote smoke (native ssh — direct + observable)
        env:
          SSH_KEY:   ${{ secrets.VOLC_SSH_KEY }}
          HOST:      ${{ secrets.VOLC_HOST }}
          SSH_USER:  ${{ secrets.VOLC_USER }}
          SMOKE_KEY: ${{ secrets.SMOKE_API_KEY }}
        run: |
          install -m 700 -d ~/.ssh
          printf '%s\n' "$SSH_KEY" > ~/.ssh/id_deploy
          chmod 600 ~/.ssh/id_deploy
          # GH secrets sometimes carry trailing whitespace; trim before passing.
          SMOKE_KEY_CLEAN=$(printf '%s' "$SMOKE_KEY" | tr -d '[:space:]')

          # Pre-flight: validate the API key directly via curl on the VPS.
          # If this 401s, the runtime never had a chance — exit fast with
          # a clear error rather than letting the CLI retry for 60s.
          echo "::group::Pre-flight key validation"
          ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
              -i ~/.ssh/id_deploy "${SSH_USER}@${HOST}" \
              "curl -s -m 10 -w '\nhttp=%{http_code} time=%{time_total}s\n' \
                  -H \"Authorization: Bearer ${SMOKE_KEY_CLEAN}\" \
                  -H 'Content-Type: application/json' \
                  -d '{\"model\":\"YOUR-DEFAULT-MODEL\",\"max_tokens\":16,\"messages\":[{\"role\":\"user\",\"content\":\"reply OK\"}]}' \
                  http://127.0.0.1:3000/v1/messages"
          echo "::endgroup::"

          ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
              -i ~/.ssh/id_deploy "${SSH_USER}@${HOST}" \
              "chown -R __RUNTIME_USER__:__RUNTIME_USER__ __INSTALL_DIR__/dist __INSTALL_DIR__/scripts && \
               chmod +x __INSTALL_DIR__/scripts/ci-smoke.sh && \
               sudo -u __RUNTIME_USER__ env ANTHROPIC_API_KEY='${SMOKE_KEY_CLEAN}' \
                 bash -c 'cd __INSTALL_DIR__ && bash scripts/ci-smoke.sh'"

      - name: Comment on PR with smoke result
        if: failure() && github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const url = `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`;
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner:        context.repo.owner,
              repo:         context.repo.repo,
              body: `__PROJECT__ smoke failed for \`${context.sha.slice(0,7)}\`. Logs: ${url}\n\n@claude please diagnose and propose a fix.`,
            })
