name: CI · Check & Local Smoke

# Agent / feature pushes get syntax check + a quick local server smoke
# (start node server.mjs with a dummy env on a free port, curl /, kill).
# Runs on PRs into both `main` and `dev` (the integration branch).
# Production deploy is in deploy.yml and only runs on push to main.

on:
  push:
    branches-ignore:
      - main
      - dev
  pull_request:
    branches: [main, dev]
  workflow_dispatch:

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  check-and-smoke:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: '22'
          cache: 'npm'

      - name: Install deps
        run: npm ci

      - name: Syntax check
        run: npm run check

      - name: Local server smoke (start → GET / → expect 200 → kill)
        env:
          PORT: 3141
          ANTHROPIC_API_KEY: smoke-dummy-key
          ANTHROPIC_BASE_URL: http://127.0.0.1:65535
          ACCESS_EMAIL: smoke@example.com
          ACCESS_PASSWORD: smoke-pass
          SESSION_SECRET: smoke-session-secret-not-real-not-real-not-real
        run: |
          node server.mjs &
          SERVER_PID=$!
          trap 'kill $SERVER_PID 2>/dev/null || true' EXIT

          for i in $(seq 1 20); do
            sleep 0.5
            code=$(curl -s -o /dev/null -w '%{http_code}' "http://127.0.0.1:${PORT}/" || echo "000")
            [ "$code" = "200" ] && { echo "Smoke OK (HTTP $code in ${i}x500ms)"; exit 0; }
          done

          echo "::error::Server did not respond 200 on / within 10s"
          curl -v "http://127.0.0.1:${PORT}/" 2>&1 | tail -30 || true
          exit 1

      - name: Comment on PR with failure
        if: failure() && github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const url = `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`;
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: `CI check failed for \`${context.sha.slice(0,7)}\`. Logs: ${url}\n\n@claude please diagnose and propose a fix.`,
            })
