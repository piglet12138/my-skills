name: Auto-PR · agent branches → dev

# Triggered when @claude pushes a feature branch. Opens a PR into dev
# and enables auto-merge so CI passing = PR merged. Idempotent: if a PR
# already exists for the branch, it just enables auto-merge on it.

on:
  push:
    branches:
      - 'claude/issue-**'

jobs:
  open-pr:
    runs-on: ubuntu-latest
    timeout-minutes: 5
    permissions:
      contents:      write
      pull-requests: write
      issues:        read
    steps:
      - name: Open PR + enable auto-merge
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          REPO:     ${{ github.repository }}
          BRANCH:   ${{ github.ref_name }}
        run: |
          set -eu

          # Skip if a PR already exists for this branch into dev
          existing=$(gh pr list --repo "$REPO" --head "$BRANCH" --base dev \
            --state open --json number --jq '.[0].number' 2>/dev/null || echo "")

          if [ -n "$existing" ]; then
            echo "PR #$existing already open for $BRANCH; ensuring auto-merge is on"
            gh pr merge "$existing" --repo "$REPO" --auto --merge || true
            exit 0
          fi

          # Extract issue number from the branch name (claude/issue-N-...)
          issue_num=$(echo "$BRANCH" | sed -nE 's|claude/issue-([0-9]+)-.*|\1|p')
          if [ -z "$issue_num" ]; then
            echo "::warning::Cannot extract issue number from branch $BRANCH; skipping"
            exit 0
          fi

          title=$(gh issue view "$issue_num" --repo "$REPO" --json title --jq '.title' 2>/dev/null || echo "$BRANCH")
          body=$(printf 'Auto-opened from `%s` via push trigger.\n\nCloses #%s\n\n🤖 Auto-PR by .github/workflows/auto-pr.yml — will auto-merge when CI passes.' "$BRANCH" "$issue_num")

          pr_url=$(gh pr create --repo "$REPO" --base dev --head "$BRANCH" \
            --title "agent: $title" --body "$body")
          echo "Opened: $pr_url"
          pr_num=$(echo "$pr_url" | grep -oE '[0-9]+$')

          # Enable auto-merge with merge strategy. Once CI (check-and-smoke)
          # passes, GitHub auto-merges into dev.
          gh pr merge "$pr_num" --repo "$REPO" --auto --merge
